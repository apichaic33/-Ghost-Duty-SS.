rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email.lower() == "q.apichai@gmail.com");
    }

    // Member rules
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.auth.token.email.lower() == "q.apichai@gmail.com" || isAdmin());
      allow update: if isAdmin() || (isOwner(memberId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lineToken']));
      allow delete: if isAdmin();
    }

    // Shift rules
    match /shifts/{shiftId} {
      allow read: if isAuthenticated();
      // Allow creation/update if admin or if the shift belongs to the user
      // In a real app, we'd want more strict validation for swaps
      allow write: if isAdmin() || isAuthenticated(); 
    }

    // SwapRequest rules
    match /swapRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.fromMemberId == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.resource.data.fromMemberId == request.auth.uid || 
        request.resource.data.toMemberId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
  }
}
