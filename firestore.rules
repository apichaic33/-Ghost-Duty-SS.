rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email.lower() == "q.apichai@gmail.com"
      );
    }

    function isMember(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Members
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || request.auth.token.email.lower() == "q.apichai@gmail.com";
      allow update: if isAdmin() || isMember(memberId);
      allow delete: if isAdmin();
    }

    // Shifts — logged-in users can read all; write own or admin writes any
    match /shifts/{shiftId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // SwapRequests — field names: requesterId / targetId
    match /swapRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.targetId    == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin() || (
        isAuthenticated() && resource.data.requesterId == request.auth.uid
      );
    }

    // Shift properties (admin manages, all members read)
    match /shiftProperties/{propId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Shift pattern templates (admin manages, all members read)
    match /shiftPatterns/{patternId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // System settings (admin manages, all members read)
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
